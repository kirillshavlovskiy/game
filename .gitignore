.DS_Store

# Environment variables - never commit secrets
local.env
.env
.env.local
.env.*.local

# Next.js
.next/
out/

# itch.io + desktop packaging (mac/win electron-builder output)
dist/

# electron-builder local caches (redirected from ~/Library/Caches when sandboxed)
.cache/

# TypeScript incremental build cache
tsconfig.tsbuildinfo

# Dependencies
node_modules/

# Python venvs / local tooling (e.g. Pillow for cover art) — thousands of site-packages files
.venv-cover/
.venv/
venv/
__pycache__/
*.pyc

# Backup
game_backup_corrupted/

# Windows artifacts
nul

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
